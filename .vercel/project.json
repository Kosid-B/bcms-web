deploy_vercel:
  name: Deploy Vercel Production
  runs-on: ubuntu-latest
  needs: migrate_supabase
  env:
    VERCEL_ORG_ID: ${{ secrets.VERCEL_ORG_ID }}
    VERCEL_PROJECT_ID: ${{ secrets.VERCEL_PROJECT_ID }}
  steps:
    - uses: actions/checkout@v4

    - uses: pnpm/action-setup@v4
      with:
        version: 10.33.2

    - uses: actions/setup-node@v4
      with:
        node-version: 22
        package-manager-cache: false

    - run: pnpm install --frozen-lockfile

    - name: Ensure clean Vercel state
      run: rm -rf .vercel && mkdir -p .vercel

    - name: Write Vercel project binding
      run: |
        printf '{"orgId":"%s","projectId":"%s","projectName":"bcms-web"}\n' "$VERCEL_ORG_ID" "$VERCEL_PROJECT_ID" > .vercel/project.json
        cat .vercel/project.json

    - name: Build Vercel artifacts
      run: npx vercel build --prod --yes --cwd . --token "${{ secrets.VERCEL_TOKEN }}"

    - name: Deploy to Vercel (production)
      run: npx vercel deploy --prebuilt --prod --yes --cwd . --token "${{ secrets.VERCEL_TOKEN }}"