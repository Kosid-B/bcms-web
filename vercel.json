{
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/((?!assets/|vite.svg|favicon.ico|robots.txt|manifest.webmanifest).*)",
      "destination": "/index.html"
    }
  ]
}
